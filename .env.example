# ==============================================================================
# LegalFlow AI - Environment Configuration Template
# Copy this file to .env and fill in the secrets for local development
# ==============================================================================

# Application Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# PostgreSQL Configuration
POSTGRES_USER=legalflow_user
POSTGRES_PASSWORD=legalflow_password_secret
POSTGRES_DB=legalflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://legalflow_user:legalflow_password_secret@postgres:5432/legalflow_db
DATABASE_URL_SYNC=postgresql://legalflow_user:legalflow_password_secret@postgres:5432/legalflow_db

#  Use direct connection here
DATABASE_URL=postgresql+asyncpg://legalflow_user:legalflow_password_secret@postgres:5432/legalflow_db
DATABASE_URL_SYNC=postgresql://legalflow_user:legalflow_password_secret@postgres:5432/legalflow_db

# Use session pooler connection for Docker
DATABASE_URL_DOCKER=postgresql+asyncpg://postgres.<project_ref>:<database_password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC_DOCKER=postgresql://postgres.<project_ref>:<database_password>@aws-<region>.pooler.supabase.com:5432/postgres

# Security & Authentication
JWT_SECRET_KEY=change_this_to_a_secure_random_key_in_production_32_bytes_min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend Service Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WEBHOOK_SECRET=webhook_secret_key_legalflow_2026

# AI Microservice Configuration
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://ai-service:8001

# RAG Service Configuration
RAG_SERVICE_HOST=0.0.0.0
RAG_SERVICE_PORT=8002
RAG_SERVICE_URL=http://rag-service:8002
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/app/data/chroma
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# OpenRouter & LLM Provider Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=mistralai/mistral-large-2411
LLM_TEMPERATURE=0.1
OPENAI_API_KEY=your_openai_api_key_optional

# n8n Automation Engine Configuration
N8N_PORT=5678
N8N_ENCRYPTION_KEY=n8n_encryption_secret_key_2026
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# File Storage Configuration
STORAGE_PATH=/app/data/storage
